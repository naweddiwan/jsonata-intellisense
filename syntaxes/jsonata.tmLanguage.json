{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JSONata",
  "scopeName": "source.jsonata",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#regex" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "name": "comment.block.jsonata", "begin": "/\\*", "end": "\\*/" }]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.jsonata", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.jsonata", "match": "\\\\." }] },
        { "name": "string.quoted.single.jsonata", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.jsonata", "match": "\\\\." }] },
        { "name": "string.quoted.other.jsonata", "begin": "`", "end": "`" }
      ]
    },
    "regex": {
      "patterns": [{ "name": "string.regexp.jsonata", "match": "/(?:[^/\\\\\\n]|\\\\.)+/[imsg]*" }]
    },
    "numbers": {
      "patterns": [{ "name": "constant.numeric.jsonata", "match": "\\b-?\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b" }]
    },
    "constants": {
      "patterns": [{ "name": "constant.language.jsonata", "match": "\\b(true|false|null)\\b" }]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.jsonata", "match": "\\b(function|and|or|in)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "support.function.builtin.jsonata", "match": "\\$(string|length|substring|substringBefore|substringAfter|uppercase|lowercase|trim|pad|contains|split|join|match|replace|eval|base64encode|base64decode|encodeUrlComponent|encodeUrl|decodeUrlComponent|decodeUrl|number|abs|floor|ceil|round|power|sqrt|random|formatNumber|formatBase|formatInteger|parseInteger|sum|max|min|average|boolean|not|exists|count|append|sort|reverse|shuffle|distinct|zip|keys|lookup|spread|merge|sift|each|error|assert|type|now|millis|fromMillis|toMillis|map|filter|single|reduce)\\b" },
        { "name": "entity.name.function.jsonata", "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*" }
      ]
    },
    "variables": {
      "patterns": [
        { "name": "variable.language.jsonata", "match": "\\$(?![a-zA-Z_])" },
        { "name": "variable.other.jsonata", "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*" }
      ]
    },
    "operators": {
      "patterns": [{ "name": "keyword.operator.jsonata", "match": "(:=|~>|\\?\\?|\\?:|==|!=|<=|>=|&&|\\|\\||\\.\\.|[=<>+\\-*/%&?:.^@#])" }]
    }
  }
}
